{
  "name": "birthday-buddy",
  "version": "1.2.2",
  "description": "Birthday Buddy Desktop App",
  "main": "index.js",
  "author": "Bob Guffie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobguffie/birthday-buddy-app.git"
  },
  "scripts": {
    "build": "tsc --skipLibCheck || (exit 0) && electron-rebuild",
    "electron:start": "npm run build && electron ./",
    "electron:pack": "electron-builder build --dir",
    "electron:make": "electron-builder build -p always"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.0",
    "chokidar": "~3.5.3",
    "electron-is-dev": "~2.0.0",
    "electron-serve": "~1.1.0",
    "electron-unhandled": "~4.0.1",
    "electron-updater": "^5.3.0",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "electron-builder": "~23.6.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.0.4"
  },
  "build": {
    "appId": "com.birthdaybuddy.app",
    "productName": "Birthday Buddy",
    "files": [
      "**/*",
      {
        "from": "src",
        "to": ".",
        "filter": ["**/*"]
      },
      "!node_modules"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": ["zip"],
      "icon": "assets/logo.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/logo.png"
    }
  }
}