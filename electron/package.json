{
  "name": "birthday-buddy",
  "version": "1.5.4",
  "description": "Birthday Buddy",
  "main": "build/src/index.js",
  "author": "Bob Guffie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobguffie/birthday-buddy-app.git"
  },
  "scripts": {
    "build": "tsc --skipLibCheck || (exit 0)",
    "electron:start": "npm run build && electron .",
    "electron:pack": "electron-builder build --dir",
    "electron:make": "electron-builder build -p always"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.0",
    "chokidar": "^3.5.3",
    "electron-is-dev": "~2.0.0",
    "electron-serve": "~1.1.0",
    "electron-unhandled": "~4.0.1",
    "electron-updater": "^5.3.0",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "electron-builder": "~23.6.0",
    "typescript": "^5.0.4"
  },
  "build": {
    "appId": "com.birthdaybuddy.app",
    "productName": "Birthday Buddy",
    "extraResources": [
      "capacitor.config.ts"
    ],
    "files": [
      "build/src/**/*.js",
      "package.json",
      "capacitor.config.json",
      "app/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["zip"],
      "icon": "assets/logo.png",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}